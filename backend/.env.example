# Your OpenAI API key for the Museum Guide
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Frontend URL for CORS if needed, defaults to *
# FRONTEND_URL=http://localhost:3000

# -----------------------------
# Database (PostgreSQL / SQLite)
# -----------------------------
# If DATABASE_URL is left blank or not set, the app will gracefully default 
# to a local SQLite file in backend/data/museum.db!
# For production (Supabase / Render / Vercel):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# -----------------------------
# Cloud Object Storage (Supabase S3)
# -----------------------------
# Required if you want to store uploaded images persistently in the cloud instead of your local machine.
# Leave blank to fallback to storing images on the server's local disk (/uploads).
# SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3
# SUPABASE_BUCKET=artworks
# AWS_ACCESS_KEY_ID=[YOUR-SUPABASE-S3-ACCESS-KEY]
# AWS_SECRET_ACCESS_KEY=[YOUR-SUPABASE-S3-SECRET-KEY]
# AWS_REGION=us-east-1
